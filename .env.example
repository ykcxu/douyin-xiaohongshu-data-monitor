TZ=Asia/Shanghai
APP_ENV=development
APP_NAME=douyin-xiaohongshu-monitor
APP_ROOT=.
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
AUTO_CREATE_SCHEMA=false
DATABASE_URL=

POSTGRES_DB=monitoring
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

BROWSER_STATE_DIR=./runtime/browser
RAW_DATA_DIR=./data/raw
SCHEDULER_ENABLED=true
LIVE_STATUS_POLL_SECONDS=300
LIVE_SNAPSHOT_POLL_SECONDS=30
DOUYIN_LIVE_PROVIDER=stub
DOUYIN_BROWSER_HEADLESS=true
